# Network
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_PREDICTIONS=false
ENABLE_TRAFFIC_METRICS=true
METRICS_LOG_INTERVAL_SECONDS=60

# Phase 0 app-level rate limiting.
# These values are intentionally above the measured local baseline so normal
# usage is allowed while bursty or runaway callers still get capped.
ENABLE_RATE_LIMIT=true
RATE_LIMIT_WINDOW_SECONDS=60
PREDICT_RATE_LIMIT=120
LOOKUP_RATE_LIMIT=180
TRAINING_DATA_RATE_LIMIT=30

# Security
# Leave API_KEY empty for local development.
API_KEY=
ENFORCE_AUTH=false

# Comma-separated list of explicit web origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000

# Comma-separated list of Chrome extension ids allowed by CORS.
# Example:
# ALLOWED_EXTENSION_IDS=abcdefghijklmnopabcdefghijklmnop
ALLOWED_EXTENSION_IDS=
